# ═══════════════════════════════════════════════════════════════
# PythonMulakat — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyala ve gerçek değerleri doldur.
# Asla gerçek .env dosyasını commit etme!
# ═══════════════════════════════════════════════════════════════

# ─── Frontend (Next.js) ────────────────────────────────────
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Backend FastAPI URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Backend (FastAPI) ─────────────────────────────────────
# Aynı Supabase projesi
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...same-as-frontend...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key-DO-NOT-EXPOSE...

# Email (Resend) — Doğrulama kodları için
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=mkemal@pythonmulakat.com

# ─── Supabase Dashboard'da Yapılacak Ayarlar ────────────────
# 1. Authentication → URL Configuration:
#    Site URL:    https://pythonmulakat.com
#    Redirect URLs:
#      - https://pythonmulakat.com/auth/callback
#      - https://pythonmulakat.com/auth/reset-password
#      - http://localhost:3000/auth/callback   (dev)
#      - http://localhost:3000/auth/reset-password  (dev)

# 2. Authentication → Providers:
#    - Email  (AÇIK) — magic link + şifre sıfırlama için
#    - Google, GitHub, vs. (opsiyonel, OAuth için)

# 3. Authentication → Email Templates:
#    - Confirm signup: linke tıklandığında /auth/callback?type=signup'a gitsin
#    - Reset password: linke tıklandığında /auth/callback?type=recovery'a gitsin
#    - Magic link:     linke tıklandığında /auth/callback?type=magiclink'a gitsin

# 4. profiles tablosuna yeni kolonlar (Supabase SQL Editor):
#    ALTER TABLE profiles ADD COLUMN IF NOT EXISTS is_verified BOOLEAN DEFAULT FALSE;
#    ALTER TABLE profiles ADD COLUMN IF NOT EXISTS verification_code TEXT;
#    ALTER TABLE profiles ADD COLUMN IF NOT EXISTS verification_code_expires_at TIMESTAMPTZ;